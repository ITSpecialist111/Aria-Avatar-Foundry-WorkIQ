# ============================================================
# Avatar Foundry — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Azure / Foundry
AZURE_TENANT_ID=
AZURE_SUBSCRIPTION_ID=
FOUNDRY_PROJECT_ENDPOINT=https://<account>.services.ai.azure.com/api/projects/<project>
VOICELIVE_ENDPOINT=https://<region>.voice.speech.microsoft.com
VOICELIVE_API_VERSION=2026-01-01-preview
SPEECH_REGION=eastus2
# Optional: API key (if local auth is enabled). Otherwise uses DefaultAzureCredential.
SPEECH_RESOURCE_KEY=
# Optional: AI Services endpoint (for Entra ID auth)
AZURE_AI_SERVICES_ENDPOINT=

# Foundry Agent (optional — without PROJECT_NAME, uses inline instructions mode)
AGENT_NAME=Aria
PROJECT_NAME=
VOICE_NAME=en-US-Ava:DragonHDLatestNeural

# Avatar
AVATAR_CHARACTER=meg
AVATAR_STYLE=casual

# Auth — Agent365-Claude-Bridge App Registration
MSAL_CLIENT_ID=9b00c7ab-2ec3-463f-9a30-0dbfbb3800af
MSAL_CLIENT_SECRET=
MSAL_TENANT_ID=

# Server
PORT=8080
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000

# Client (Vite — prefix with VITE_)
VITE_MSAL_CLIENT_ID=9b00c7ab-2ec3-463f-9a30-0dbfbb3800af
VITE_MSAL_TENANT_ID=
VITE_MSAL_REDIRECT_URI=http://localhost:3000
